{
    "openapi": "3.0.0",
    "info": {
        "title": "Meetup Football API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local development server"
        }
    ],
    "paths": {
        "/api/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register a new user",
                "operationId": "d764dd091cc4494ae0baf360b03319f3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Pepito"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "pepito@test.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "Password987"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "Password987"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "666666666"
                                    },
                                    "skill_level": {
                                        "type": "string",
                                        "enum": [
                                            "beginner",
                                            "intermediate",
                                            "advanced"
                                        ]
                                    },
                                    "favourite_position": {
                                        "type": "string",
                                        "enum": [
                                            "goalkeeper",
                                            "defender",
                                            "midfielder",
                                            "striker"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login user and get token",
                "operationId": "8dcb70df1020986038d098cc08d05dae",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "pepito@test.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "Password987"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "eyJ0eXAiOiJKV1QiLCJhbGci..."
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout user and revoke token",
                "operationId": "69281b12abb272c76871f19cb17ca563",
                "responses": {
                    "200": {
                        "description": "Logged out successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Logged out successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches/{footballMatch}/comments": {
            "get": {
                "tags": [
                    "Comments"
                ],
                "summary": "Get comments of a match",
                "operationId": "cf9a4c0dc18b479fe023296c8586b018",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of comments"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Comments"
                ],
                "summary": "Create a comment for a match",
                "operationId": "560dce054e7a6fd34b99a1a880b75e69",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "content"
                                ],
                                "properties": {
                                    "content": {
                                        "type": "string",
                                        "example": "Apuntado al partido!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Comment created successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches": {
            "get": {
                "tags": [
                    "Matches"
                ],
                "summary": "Get list of matches",
                "operationId": "c0735c7be1ec75cab53dd45bfed420ef",
                "responses": {
                    "200": {
                        "description": "List of matches"
                    }
                }
            },
            "post": {
                "tags": [
                    "Matches"
                ],
                "summary": "Create a new match",
                "operationId": "6d1c46be4db252cc42bd1a24914b76bb",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "starts_at",
                                    "duration",
                                    "match_type",
                                    "max_players",
                                    "location_name",
                                    "address",
                                    "city"
                                ],
                                "properties": {
                                    "description": {
                                        "type": "string",
                                        "example": "Partido de futbol casual"
                                    },
                                    "starts_at": {
                                        "type": "string",
                                        "example": "2026-04-01 18:00:00"
                                    },
                                    "duration": {
                                        "type": "integer",
                                        "example": 90
                                    },
                                    "match_type": {
                                        "type": "string",
                                        "example": "7v7"
                                    },
                                    "max_players": {
                                        "type": "integer",
                                        "example": 14
                                    },
                                    "required_level": {
                                        "type": "string",
                                        "enum": [
                                            "beginner",
                                            "intermediate",
                                            "advanced"
                                        ]
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 5
                                    },
                                    "location_name": {
                                        "type": "string",
                                        "example": "Camp Municipal"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Carrer Gran Via 1"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Barcelona"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Match created successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches/{footballMatch}": {
            "get": {
                "tags": [
                    "Matches"
                ],
                "summary": "Get a match by ID",
                "operationId": "65ff32a940e20c21994a325890150c37",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Match details"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                }
            },
            "put": {
                "tags": [
                    "Matches"
                ],
                "summary": "Update a match",
                "operationId": "9c25d3b62e762ec2f29985ed0fb4bc5a",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "description": {
                                        "type": "string",
                                        "example": "Partido modificado"
                                    },
                                    "starts_at": {
                                        "type": "string",
                                        "example": "2026-04-01 18:00:00"
                                    },
                                    "duration": {
                                        "type": "integer",
                                        "example": 90
                                    },
                                    "match_type": {
                                        "type": "string",
                                        "example": "7v7"
                                    },
                                    "max_players": {
                                        "type": "integer",
                                        "example": 14
                                    },
                                    "required_level": {
                                        "type": "string",
                                        "enum": [
                                            "beginner",
                                            "intermediate",
                                            "advanced"
                                        ]
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 5
                                    },
                                    "location_name": {
                                        "type": "string",
                                        "example": "Camp Municipal"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Carrer Gran Via 1"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Barcelona"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "open",
                                            "full",
                                            "cancelled"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Match updated successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Matches"
                ],
                "summary": "Delete a match",
                "operationId": "14612e734d23d8cf6ad32497c4ae1d65",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Match deleted successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches/count": {
            "get": {
                "tags": [
