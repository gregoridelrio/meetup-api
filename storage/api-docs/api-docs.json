{
    "openapi": "3.0.0",
    "info": {
        "title": "Meetup Football API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local development server"
        }
    ],
    "paths": {
        "/api/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register a new user",
                "operationId": "dbbeb34bb1676cb88fa23f12e43b6ec0",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Pepito"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "pepito@test.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "Password987"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "Password987"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "666666666"
                                    },
                                    "skill_level": {
                                        "type": "string",
                                        "enum": [
                                            "beginner",
                                            "intermediate",
                                            "advanced"
                                        ]
                                    },
                                    "favourite_position": {
                                        "type": "string",
                                        "enum": [
                                            "goalkeeper",
                                            "defender",
                                            "midfielder",
                                            "striker"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login user and get token",
                "operationId": "c34dec07634d0bdcec1c5ce5b64d6c98",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "pepito@test.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "Password987"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "eyJ0eXAiOiJKV1QiLCJhbGci..."
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout user and revoke token",
                "operationId": "5690fc0e883dcb2758c97a6fce552656",
                "responses": {
                    "200": {
                        "description": "Logged out successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Logged out successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches/{footballMatch}/comments": {
            "get": {
                "tags": [
                    "Comments"
                ],
                "summary": "Get comments of a match",
                "operationId": "5b8c40899f1042a62f0b051a1d15299c",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of comments"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                }
            },
            "post": {
                "tags": [
                    "Comments"
                ],
                "summary": "Create a comment for a match",
                "operationId": "ae6b823fb3ac94caf085db73670bd67a",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "content"
                                ],
                                "properties": {
                                    "content": {
                                        "type": "string",
                                        "example": "¡Apuntado al partido!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Comment created successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches": {
            "get": {
                "tags": [
                    "Matches"
                ],
                "summary": "Get list of matches",
                "operationId": "25f4b6ec0caf0d2a935e30b1855f9075",
                "responses": {
                    "200": {
                        "description": "List of matches"
                    }
                }
            },
            "post": {
                "tags": [
                    "Matches"
                ],
                "summary": "Create a new match",
                "operationId": "e9cecf0eadfc2ef12061d9b6bf0af32b",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "starts_at",
                                    "duration",
                                    "match_type",
                                    "max_players",
                                    "location_name",
                                    "address",
                                    "city"
                                ],
                                "properties": {
                                    "description": {
                                        "type": "string",
                                        "example": "Partido de futbol casual"
                                    },
                                    "starts_at": {
                                        "type": "string",
                                        "example": "2026-04-01 18:00:00"
                                    },
                                    "duration": {
                                        "type": "integer",
                                        "example": 90
                                    },
                                    "match_type": {
                                        "type": "string",
                                        "example": "7v7"
                                    },
                                    "max_players": {
                                        "type": "integer",
                                        "example": 14
                                    },
                                    "required_level": {
                                        "type": "string",
                                        "enum": [
                                            "beginner",
                                            "intermediate",
                                            "advanced"
                                        ]
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 5
                                    },
                                    "location_name": {
                                        "type": "string",
                                        "example": "Camp Municipal"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Carrer Gran Via 1"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Barcelona"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Match created successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches/{footballMatch}": {
            "get": {
                "tags": [
                    "Matches"
                ],
                "summary": "Get a match by ID",
                "operationId": "251f16463ce5ce2b9e36b61278794125",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Match details"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                }
            },
            "put": {
                "tags": [
                    "Matches"
                ],
                "summary": "Update a match",
                "operationId": "89d5faa6c9a744d64d75d2c681937278",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "description": {
                                        "type": "string",
                                        "example": "Partido modificado"
                                    },
                                    "starts_at": {
                                        "type": "string",
                                        "example": "2026-04-01 18:00:00"
                                    },
                                    "duration": {
                                        "type": "integer",
                                        "example": 90
                                    },
                                    "match_type": {
                                        "type": "string",
                                        "example": "7v7"
                                    },
                                    "max_players": {
                                        "type": "integer",
                                        "example": 14
                                    },
                                    "required_level": {
                                        "type": "string",
                                        "enum": [
                                            "beginner",
                                            "intermediate",
                                            "advanced"
                                        ]
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 5
                                    },
                                    "location_name": {
                                        "type": "string",
                                        "example": "Camp Municipal"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Carrer Gran Via 1"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Barcelona"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "open",
                                            "full",
                                            "cancelled"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Match updated successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Matches"
                ],
                "summary": "Delete a match",
                "operationId": "680733370ed86192b9f49084b626f4f5",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Match deleted successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Match not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/matches/{footballMatch}/players": {
            "get": {
                "tags": [
                    "Registrations"
                ],
                "summary": "Get players registered to a match",
                "operationId": "19230d0c47a68072dcab9041531d83e1",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of players"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Registrations"
                ],
                "summary": "Register for a match",
                "operationId": "4533c4177ecab9620413283e1b4d0301",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Registered successfully"
                    },
                    "400": {
                        "description": "Match is full or already registered"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Registrations"
                ],
                "summary": "Unregister from a match",
                "operationId": "a01c5b99473dc1418ec2082e1fe37d89",
                "parameters": [
                    {
                        "name": "footballMatch",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Unregistered successfully"
                    },
                    "400": {
                        "description": "Not registered for this match"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/users/matches": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Get matches of authenticated user",
                "operationId": "1de1adeb3caaf48d9f8a36e47e15e222",
                "responses": {
                    "200": {
                        "description": "List of user matches"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/users/stats": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Get activity statistics and rank of the authenticated user",
                "operationId": "d0f288edf42185234d921229c8cfc986",
                "responses": {
                    "200": {
                        "description": "User statistics calculated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "matches_organized": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "matches_joined": {
                                            "type": "integer",
                                            "example": 0
                                        },
                                        "total_comments": {
                                            "type": "integer",
                                            "example": 0
                                        },
                                        "activity_score": {
                                            "type": "integer",
                                            "example": 10
                                        },
                                        "rank": {
                                            "type": "string",
                                            "example": "Rookie",
                                            "enum": [
                                                "Rookie",
                                                "Amateur",
                                                "Pro",
                                                "Legend"
                                            ]
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/users/profile": {
            "patch": {
                "tags": [
                    "User"
                ],
                "summary": "Update authenticated user profile",
                "operationId": "bbae4ab5a966b4740f7cb28e687ab954",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "nullable": true,
                                        "maxLength": 9
                                    },
                                    "skill_level": {
                                        "type": "string",
                                        "enum": [
                                            "beginner",
                                            "intermediate",
                                            "advanced"
                                        ]
                                    },
                                    "favourite_position": {
                                        "type": "string",
                                        "enum": [
                                            "goalkeeper",
                                            "defender",
                                            "midfielder",
                                            "striker"
                                        ]
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "minLength": 8
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profile updated successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Enter JWT Bearer token",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
